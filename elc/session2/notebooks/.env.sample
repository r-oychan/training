# Provider: "local" (Ollama) or "azure" (Azure AI Foundry)
# Set to "local" to use Ollama running on your machine
# Set to "azure" to use Azure AI Foundry endpoints
PROVIDER=local

# --- Local (Ollama) ---
# Base URL for Ollama API (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
# Model used for embeddings and text chat (must be pulled: ollama pull phi3:mini)
OLLAMA_MODEL=phi3:mini
# Separate models for VLM RAG (notebook 03)
OLLAMA_EMBED_MODEL=phi3:mini
OLLAMA_CHAT_MODEL=phi3:mini
# Vision model for page description and answering (must be pulled: ollama pull qwen3.5:4b)
OLLAMA_VLM_MODEL=qwen3.5:4b

# --- OpenAI (notebook 01 — chat completion seed demo) ---
# OPENAI_API_KEY=<your-openai-api-key>
# OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions
# OPENAI_MODEL=gpt-4o-mini

# --- Azure AI Foundry (OpenAI-compatible) ---
# API key from Azure AI Foundry portal > your project > Keys
AZURE_API_KEY=<your-azure-api-key>

# Chat completion endpoint (text-only, used for reranking)
# Format: https://<resource-name>.openai.azure.com/openai/v1
AZURE_CHAT_BASE_URL=https://<resource-name>.openai.azure.com/openai/v1
# Deployment name for chat model (e.g. gpt-4o, gpt-5.2)
AZURE_CHAT_DEPLOYMENT=gpt-4o

# VLM endpoint (vision-capable model, used for page description + answering)
# Must support image inputs — gpt-4o and gpt-5.2 both work
# Format: https://<resource-name>.openai.azure.com/openai/v1
AZURE_VLM_BASE_URL=https://<resource-name>.openai.azure.com/openai/v1
# Deployment name for vision model
AZURE_VLM_DEPLOYMENT=gpt-4o

# Embeddings endpoint (can be same or different resource)
# Format: https://<resource-name>.openai.azure.com/openai/v1
AZURE_EMBED_BASE_URL=https://<resource-name>.openai.azure.com/openai/v1
# Deployment name for embedding model (e.g. text-embedding-ada-002, text-embedding-3-small)
AZURE_EMBED_DEPLOYMENT=text-embedding-ada-002
